# Zoho Smart Kiosk -- Configuration
# Copy to .env and fill in your values.

# Zoho Kiosk URL (Zoho People > Attendance > Kiosk > Open Kiosk)
ZOHO_KIOSK_URL=https://people.zoho.in/YourCompanyName/kiosk

# ESP32-CAM network settings
ESP32_CAM_IP=192.168.1.151
ESP32_CAM_PORT=80
ESP32_CAM_STREAM_PATH=/stream

# Display resolution (virtual display / HDMI output)
SCREEN_RESOLUTION=1280x800x24

# VNC access (remote kiosk management)
VNC_PORT=5900
VNC_PASSWORD=zoho1234

# Chrome DevTools Protocol (internal use by middleware)
CDP_PORT=9222

# Middleware dashboard port
MIDDLEWARE_PORT=5003

# Timezone
TZ=Asia/Kolkata
