# =============================================================================
# ZOHO SMART KIOSK — Main Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ── Zoho ─────────────────────────────────────────────────────────────────────
# Your Zoho Kiosk URL (get it from Zoho People → Attendance → Kiosk → Open Kiosk)
ZOHO_KIOSK_URL=https://people.zoho.in/YourCompanyName/kiosk

# ── ESP32-CAM ─────────────────────────────────────────────────────────────────
# The local IP address the ESP32-CAM gets after connecting to your WiFi.
# Check your router's DHCP list, or read Serial Monitor after flashing.
ESP32_CAM_IP=192.168.1.101
ESP32_CAM_PORT=80
ESP32_CAM_STREAM_PATH=/stream

# ── Display ───────────────────────────────────────────────────────────────────
# Resolution of your HDMI monitor at reception (or virtual display)
SCREEN_RESOLUTION=1280x800x24

# VNC port for remote management (connect with any VNC viewer to server-ip:5900)
VNC_PORT=5900

# Chrome DevTools Protocol port (used internally by middleware — do not expose externally)
CDP_PORT=9222

# ── Middleware ────────────────────────────────────────────────────────────────
MIDDLEWARE_PORT=5003

# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata
